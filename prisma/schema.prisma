datasource db {
  provider = "postgresql"
  // url is intentionally removed to comply with Prisma 7 config standards
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// CORE ENUMS
// ==========================================
enum Role {
  SUPER_ADMIN
  ADMIN
  HR
  STAFF
  EXEC
  IT_DIGITAL
  FINANCE_TREASURY
  LEGAL
  OPERATIONS
  COMPLIANCE
  MARKETING_COMMUNICATION
  CREDIT_RISK
  AUDIT
  RECOVERY
  CUSTOMER_EXPERIENCE
  SAVINGS_MOBILISATION
  ENGINEERING
}

enum AccountStatus { 
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  TERMINATED 
}

enum LeaveStatus { 
  PENDING
  APPROVED
  ACTIVE
  PAUSED
  COMPLETED
  REJECTED 
}

enum LeaveType { 
  ANNUAL
  SICK
  PREGNANCY_MATERNITY
  UNPAID 
}

enum Severity { 
  INFO
  WARNING
  CRITICAL 
}

enum KycStatus { 
  PENDING
  VERIFIED
  REJECTED
  EXPIRED 
}

enum AccountType { 
  CHECKING
  SAVINGS
  LOAN
  INVESTMENT 
}

// PHASE 5 ENUMS
enum Station { 
  TELLER_COUNTER
  VAULT_CUSTODIAN
  CUSTOMER_SERVICE
  BACK_OFFICE
  SECURITY_DESK 
}

enum ShiftStatus { 
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  ABSENT 
}

// PHASE 6 ENUMS
enum CertStatus { 
  VALID
  EXPIRING_SOON
  EXPIRED
  REVOKED 
}

enum OkrStatus { 
  ON_TRACK
  AT_RISK
  BEHIND
  COMPLETED 
}

// PHASE 7 ENUMS
enum WorkflowType { 
  EXPENSE_REQUISITION
  DEPARTMENT_TRANSFER
  SALARY_ADJUSTMENT
  POLICY_EXCEPTION 
}

enum WorkflowStatus { 
  DRAFT
  IN_PROGRESS
  APPROVED
  REJECTED
  CANCELLED 
}

enum StepStatus { 
  PENDING
  APPROVED
  REJECTED
  SKIPPED 
}

// PHASE 8 ENUMS
enum AssetStatus {
  ASSIGNED
  IN_REPAIR
  RETURNED
  LOST_STOLEN
}

// PHASE 9: RESOURCES & REQUISITION ENUMS
enum PolicyCategory {
  HR_GUIDELINES
  IT_SECURITY
  COMPLIANCE_AML
  BRANCH_OPERATIONS
  GENERAL
}

enum AssetRequestStatus {
  PENDING
  APPROVED
  FULFILLED
  REJECTED
}

// ==========================================
// CORE MODELS
// ==========================================
model Branch {
  id          String   @id @default(cuid())
  name        String   @unique
  location    String
  established DateTime @default(now())
  
  users       User[]
  shifts      Shift[]
  assets      HardwareAsset[]
}

model User {
  id                  String         @id @default(cuid())
  email               String         @unique
  password            String         
  name                String
  role                Role           @default(STAFF)
  status              AccountStatus  @default(PENDING_APPROVAL)
  isDepartmentLead    Boolean        @default(false)
  
  phone               String?
  birthDate           DateTime?
  nin                 String?        @unique
  bvn                 String?        @unique
  address             String?
  avatarUrl           String?        
  cvUrl               String?        
  
  branchId            String?
  branch              Branch?        @relation(fields: [branchId], references: [id])
  salaryAccountNumber String?
  bankName            String?
  nextPayDate         DateTime?      
  baseSalary          Float?
  isOnline            Boolean        @default(false)
  
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  
  // Relations
  payrolls            Payroll[]
  leaveRequests       LeaveRequest[]
  auditLogs           AuditLog[]
  managedCustomers    Customer[]
  sentMessages        Message[]      @relation("SentMessages")
  receivedMessages    Message[]      @relation("ReceivedMessages")
  notifications       Notification[]
  
  shifts              Shift[]
  delegationsGiven    Delegation[]   @relation("Delegator")
  delegationsReceived Delegation[]   @relation("Delegatee")
  
  certifications      Certification[]
  objectives          Objective[]

  initiatedWorkflows  WorkflowRequest[] @relation("InitiatedWorkflows")
  assignedSteps       WorkflowStep[]    @relation("AssignedSteps")
  actedSteps          WorkflowStep[]    @relation("ActedSteps")

  // Phase 8 Relations
  assets                HardwareAsset[]     @relation("AssignedAssets")
  offboardingRecord     OffboardingRecord?
  processedOffboardings OffboardingRecord[] @relation("ProcessedOffboardings")

  // Phase 9 Relations
  authoredPolicies      CompanyPolicy[] @relation("PolicyAuthor")
  assetRequests         AssetRequest[]  @relation("AssetRequester")
  approvedAssetRequests AssetRequest[]  @relation("AssetApprover")
}

model Payroll {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  baseSalary  Float
  allowances  Float    @default(0)
  dedctions   Float    @default(0)
  netPay      Float
  payPeriod   String   
  isPaid      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model LeaveRequest {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  type          LeaveType   @default(ANNUAL)
  startDate     DateTime
  endDate       DateTime
  totalDays     Int
  daysRemaining Int
  pausedAt      DateTime?   
  reason        String?
  status        LeaveStatus @default(PENDING)
  approverId    String?     
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId, createdAt])
  @@index([status]) 
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  
  user       User?    @relation(fields: [userId], references: [id])
  action     String   
  entityType String   
  entityId   String?  
  details    Json     
  ipAddress  String?  
  userAgent  String?
  severity   Severity @default(INFO)
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
}

model Customer {
  id                String        @id @default(cuid())
  firstName         String
  lastName          String
  email             String        @unique
  phone             String
  dateOfBirth       DateTime
  taxId             String?       @unique 
  address           String
  kycStatus         KycStatus     @default(PENDING)
  assignedManagerId String?       
  assignedManager   User?         @relation(fields: [assignedManagerId], references: [id])
  accounts          Account[]
  documents         KycDocument[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([lastName, firstName])
  @@index([kycStatus])
}

model Account {
  id            String      @id @default(cuid())
  accountNumber String      @unique
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  type          AccountType
  balance       Float       @default(0.0)
  currency      String      @default("USD")
  isActive      Boolean     @default(true)
  openedAt      DateTime    @default(now())

  @@index([customerId])
}

model KycDocument {
  id           String    @id @default(cuid())
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id])
  documentType String   
  fileUrl      String   
  uploadedAt   DateTime  @default(now())
  verifiedAt   DateTime?
  verifiedBy   String?  
}

model Message {
  id         String   @id @default(cuid())
  content    String?  
  imageUrl   String?  // Store S3/UploadThing URL here
  isDeleted  Boolean  @default(false)
  
  senderId   String
  receiverId String?  // Optional for global admin broadcasts
  
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User?    @relation("ReceivedMessages", fields: [receiverId], references: [id])
  
  createdAt  DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   @default("SYSTEM")
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model Shift {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  date        DateTime    
  startTime   DateTime    
  endTime     DateTime    
  station     Station     @default(BACK_OFFICE)
  status      ShiftStatus @default(SCHEDULED)
  notes       String?     
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([branchId, date]) 
  @@index([userId, date])
}

model Delegation {
  id              String   @id @default(cuid())
  delegatorId     String
  delegator       User     @relation("Delegator", fields: [delegatorId], references: [id])
  delegateeId     String
  delegatee       User     @relation("Delegatee", fields: [delegateeId], references: [id])
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean  @default(true)
  departmentRole  Role     
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([delegatorId])
  @@index([delegateeId])
  @@index([isActive])
}

model Certification {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String     
  issuer          String     
  issuedAt        DateTime
  expiresAt       DateTime
  status          CertStatus @default(VALID)
  documentUrl     String?    
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([expiresAt])
  @@index([status])
}

model Objective {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String    
  description     String?
  targetValue     Float     
  currentValue    Float     @default(0)
  metric          String    
  deadline        DateTime
  status          OkrStatus @default(ON_TRACK)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, status])
}

model WorkflowRequest {
  id               String         @id @default(cuid())
  initiatorId      String
  initiator        User           @relation("InitiatedWorkflows", fields: [initiatorId], references: [id], onDelete: Cascade)
  type             WorkflowType
  title            String
  details          Json           
  status           WorkflowStatus @default(IN_PROGRESS)
  currentStepIndex Int            @default(0) 
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  steps            WorkflowStep[]

  @@index([initiatorId])
  @@index([status])
}

model WorkflowStep {
  id              String          @id @default(cuid())
  workflowId      String
  workflow        WorkflowRequest @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepOrder       Int             
  requiredRoleId  Role?           
  specificUserId  String?
  assignedUser    User?           @relation("AssignedSteps", fields: [specificUserId], references: [id])
  status          StepStatus      @default(PENDING)
  comments        String?         
  actedById       String?
  actor           User?           @relation("ActedSteps", fields: [actedById], references: [id])
  actedAt         DateTime?
  createdAt       DateTime        @default(now())

  @@unique([workflowId, stepOrder])
}

// ============================================================================
// PHASE 8: ASSETS & OFFBOARDING ENGINE
// ============================================================================
model HardwareAsset {
  id              String      @id @default(cuid())
  tagNumber       String      @unique // e.g., "LT-2026-89"
  deviceType      String      // e.g., "MacBook Pro", "Teller Scanner"
  
  assignedToId    String?
  assignedTo      User?       @relation("AssignedAssets", fields: [assignedToId], references: [id])
  
  branchId        String
  branch          Branch      @relation(fields: [branchId], references: [id])
  
  status          AssetStatus @default(ASSIGNED)
  issuedAt        DateTime    @default(now())
  returnedAt      DateTime?

  @@index([assignedToId])
  @@index([branchId])

  // Phase 9 Link
  fulfilledRequest AssetRequest?
}

model OffboardingRecord {
  id              String      @id @default(cuid())
  userId          String      @unique // One offboarding record per terminated user
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  processedById   String
  processedBy     User        @relation("ProcessedOffboardings", fields: [processedById], references: [id])
  
  payrollFrozen   Boolean     @default(false)
  accessRevoked   Boolean     @default(false)
  assetsRecovered Boolean     @default(false)
  
  notes           String?
  createdAt       DateTime    @default(now())
}

// ============================================================================
// PHASE 9: INTERNAL KNOWLEDGE BASE
// ============================================================================
model CompanyPolicy {
  id          String         @id @default(cuid())
  title       String
  content     String         @db.Text // Store Markdown or Rich Text HTML here
  category    PolicyCategory @default(GENERAL)
  isPublished Boolean        @default(true)
  
  authorId    String
  author      User           @relation("PolicyAuthor", fields: [authorId], references: [id])
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  @@index([category, isPublished])
}

// ============================================================================
// PHASE 9: ASSET REQUISITION TICKETS
// ============================================================================
model AssetRequest {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation("AssetRequester", fields: [userId], references: [id], onDelete: Cascade)
  
  deviceType      String             // e.g., "MacBook Pro", "Ergonomic Chair"
  reason          String             // The business justification
  status          AssetRequestStatus @default(PENDING)
  
  // Who approved it (HR/IT Lead)
  approverId      String?
  approver        User?              @relation("AssetApprover", fields: [approverId], references: [id])
  
  // Link to the actual hardware once IT fulfills the ticket
  fulfilledWithId String?            @unique
  fulfilledWith   HardwareAsset?     @relation(fields: [fulfilledWithId], references: [id])
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId, status])
}
